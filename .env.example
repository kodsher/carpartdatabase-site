# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Domain
NEXT_PUBLIC_DOMAIN=carpartdatabase.com

# Scraper Path (path to the ebay-scraper-csv.js file on the worker server)
# For local development: /Users/admin/Desktop/puppeteer/ebay-scraper-csv.js
# For production: /path/to/scraper/ebay-scraper-csv.js
NEXT_PUBLIC_SCRAPER_PATH=/Users/admin/Desktop/puppeteer/ebay-scraper-csv.js
